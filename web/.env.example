# Copy to .env and fill in — same convention as api/.env.example.
#
# NEXT_PUBLIC_* is required for a var to be readable in client-side/browser code — Next.js
# only inlines env vars into the browser bundle when they carry this prefix. Server-only code
# (Server Components, Route Handlers) can read unprefixed vars too, but there are none of
# those here yet.
#
# If the team later adds a real Cloudflare Workers binding (an R2 bucket, KV, D1 — not just a
# plain string like this one), that specifically needs .dev.vars (or wrangler.jsonc), since
# only Cloudflare's own binding system creates those objects — a plain .env var can't.

# finance-tracking-api — local mock server by default (see api/README.md).
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
